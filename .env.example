# Server
NODE_ENV=development
PORT=8080

# Public URL for this backend deployment
PUBLIC_BASE_URL=https://thinkpulse-api-cpdre8hrencgaagx.centralindia-01.azurewebsites.net

# Razorpay (used by /create-order, /create-qr, /verify-payment, /webhook)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Stripe keys
STRIPE_TEST_PUBLISHABLE_KEY=
STRIPE_TEST_SECRET_KEY=
STRIPE_LIVE_PUBLISHABLE_KEY=
STRIPE_LIVE_SECRET_KEY=

# Use one mode at a time in backend runtime
# MODE=test -> uses STRIPE_TEST_SECRET_KEY and STRIPE_WEBHOOK_SECRET_TEST
# MODE=live -> uses STRIPE_LIVE_SECRET_KEY and STRIPE_WEBHOOK_SECRET_LIVE
MODE=test

# Webhook secrets
STRIPE_WEBHOOK_SECRET_TEST=
STRIPE_WEBHOOK_SECRET_LIVE=

# Price IDs
STRIPE_PRICE_BASIC_EXAM_INR_10=
STRIPE_PRICE_PREMIUM_EXAM_INR_20=

# Business/display
STRIPE_STATEMENT_DESCRIPTOR=THINKPULSE
SUPPORT_EMAIL=
SUPPORT_PHONE=

# URLs (defaults are auto-built from PUBLIC_BASE_URL if omitted)
TERMS_URL=
PRIVACY_URL=
REFUND_POLICY_URL=
WEBHOOK_URL=
RAZORPAY_WEBHOOK_URL=
SUCCESS_URL=
CANCEL_URL=

# CORS allowlist (comma-separated). Example:
# CORS_ORIGINS=chrome-extension://abcdefghijklmnopabcdefghijklmnop,https://thinkpulse-api-cpdre8hrencgaagx.centralindia-01.azurewebsites.net
CORS_ORIGINS=

# Admin runtime pool (moved from frontend hardcoded defaults)
ADMIN_OPENROUTER_KEYS=
ADMIN_GEMINI_KEYS=

ADMIN_DEEPSEEK_KEY=
ADMIN_DEEPSEEK_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions
ADMIN_DEEPSEEK_MODEL=deepseek-ai/deepseek-v3.2

ADMIN_QWEN_KEY=
ADMIN_QWEN_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions
ADMIN_QWEN_MODEL=qwen/qwen2.5-coder-7b-instruct

ADMIN_LLAMA_PRIMARY_KEY=
ADMIN_LLAMA_PRIMARY_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions
ADMIN_LLAMA_PRIMARY_MODEL=meta/llama-3.1-70b-instruct

ADMIN_VISION_KEY=
ADMIN_VISION_ENDPOINT=https://integrate.api.nvidia.com/v1/chat/completions
ADMIN_VISION_MODEL=nvidia/nemotron-nano-12b-v2-vl

ADMIN_IMAGE_GEN_KEY=
ADMIN_IMAGE_GEN_ENDPOINT=https://integrate.api.nvidia.com/v1/images/generations
ADMIN_IMAGE_GEN_MODEL=stable-diffusion-3.5-large

ADMIN_OCRSPACE_KEY=
ADMIN_OCRSPACE_ENDPOINT=https://api.ocr.space/parse/image

ADMIN_NVIDIA_OCR_KEY=
ADMIN_NVIDIA_OCR_ENDPOINT=https://integrate.api.nvidia.com/v1/ocr
ADMIN_NVIDIA_OCR_MODEL=nemoretriever-ocr-v1

ADMIN_ASR_KEY=
ADMIN_ASR_ENDPOINT=https://integrate.api.nvidia.com/v1/audio/transcriptions
ADMIN_ASR_MODEL=ai-parakeet-ctc-1.1b-asr

# Optional web-search defaults for first-time extension setup
DEFAULT_TAVILY_SEARCH_KEYS=
DEFAULT_SERPER_SEARCH_KEYS=

# Supabase payment persistence
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional fallback when service role key is unavailable
SUPABASE_SECRET_KEY=
